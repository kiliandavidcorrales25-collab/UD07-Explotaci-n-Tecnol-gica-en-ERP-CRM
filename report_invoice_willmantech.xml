<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_invoice_willmantech">

        <t t-call="web.external_layout">

            <t t-set="mostrar_descuento"
               t-value="any(line.discount for line in doc.invoice_line_ids)"/>

            <div class="page">
                <h2>WillmanTech S.L.</h2>
                <h3>Departamento facturas</h3>
                <h3>Sevilla, España</h3>
                <h2>
                    Factura N.º:
                    <span t-field="doc.name"/>
                </h2>
                <p>
                    <strong>Fecha de emisión:</strong>
                    <span t-field="doc.invoice_date"/>
                </p>
                <p>
                    <strong>Cliente:</strong>
                    <span t-field="doc.partner_id.name"/>
                </p>
                <p>
                    <strong>Correo electrónico:</strong>
                    <span t-field="doc.partner_id.email"/>
                </p>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Descripción</th>
                            <th class="text-right">Cantidad</th>
                            <th class="text-right">Precio unitario</th>

                            <th t-if="mostrar_descuento"
                                class="text-right">
                                Descuento
                            </th>
                            <th class="text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="doc.invoice_line_ids" t-as="line">
                            <tr>
                                <td>
                                    <span t-field="line.name"/>
                                </td>

                                <td class="text-right">
                                    <span t-field="line.quantity"/>
                                </td>

                                <td class="text-right">
                                    <span t-field="line.price_unit"/>
                                </td>

                                <td t-if="mostrar_descuento"
                                    class="text-right">
                                    <span t-field="line.discount"/>
                                </td>

                                <td class="text-right">
                                    <span t-field="line.price_subtotal"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>

                </table>
                <p class="text-right">
                    <strong>Total:</strong>
                    <span t-field="doc.amount_total"/>
                </p>
            </div>

        </t>
    </template>
</odoo>
